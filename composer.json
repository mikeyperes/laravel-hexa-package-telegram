{
    "name": "hexawebsystems/laravel-hexa-package-telegram",
    "description": "Telegram bot notifications and commands for the Hexa Core framework.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "hexa_package_telegram\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "hexa_package_telegram\\Providers\\TelegramServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
